# API Keys para o Roteiro a Dois
# Copie este arquivo para .env.local e preencha os valores

# TMDB - Filmes e Séries (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# Geoapify - Restaurantes e Lugares (https://myprojects.geoapify.com)
GEOAPIFY_API_KEY=

# Ticketmaster - Eventos e Shows (https://developer.ticketmaster.com)
TICKETMASTER_API_KEY=

# OpenWeatherMap - Clima (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# TheMealDB - NÃO PRECISA DE KEY (usa key de teste '1' automaticamente)

# Backend full stack - opcional no deploy inicial
# Use quando services/api estiver publicado fora da Vercel.
NEXT_PUBLIC_LIFE_API_URL=
